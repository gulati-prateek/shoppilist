rules_version = '2';

// ShoppiList Firestore rules. Paste into Firebase console -> Firestore Database -> Rules
// (or deploy with `firebase deploy --only firestore:rules`).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Master item catalog: everyone signed-in reads; only admins write (the seed script uses
    // the Admin SDK, which bypasses rules).
    match /catalog/{region}/items/{itemId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Off-catalog items reported by users. Any signed-in user may create/update a report
    // (repeat adds merge into one doc); only admins may read the review queue or delete.
    match /custom_items/{reportId} {
      allow create, update: if signedIn();
      allow read, delete: if isAdmin();
    }

    // Profile mirror: owners manage their own doc; admins may read (location/address info).
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // Admin markers: a user may check their own admin status; nobody writes from the client
    // (manage via Firebase console or the seed script).
    match /admins/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list, write: if false;
    }

    // ---- Collaboration (Phase 4) ----

    function isMember(listId) {
      return signedIn()
        && exists(/databases/$(database)/documents/lists/$(listId)/members/$(request.auth.uid));
    }

    // Role-gated writes: VIEWER members can read everything but change nothing (B6).
    function canEdit(listId) {
      return signedIn()
        && get(/databases/$(database)/documents/lists/$(listId)/members/$(request.auth.uid))
             .data.role in ['OWNER', 'EDITOR'];
    }

    // Shared lists: a signed-in user may create a list (they set themselves as owner); every
    // member reads; only OWNER/EDITOR members mutate.
    match /lists/{listId} {
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isMember(listId);
      allow update, delete: if canEdit(listId);

      match /items/{itemId} {
        allow read: if isMember(listId);
        allow write: if canEdit(listId);
      }
      match /activity/{activityId} {
        allow read: if isMember(listId);
        allow write: if canEdit(listId);
      }
      // Members: a member reads the roster; a user may add themselves (accepting an invite) or an
      // OWNER/EDITOR may manage members; anyone may delete THEIR OWN member doc (leaving a list).
      match /members/{uid} {
        allow read: if isMember(listId);
        allow create: if signedIn() && (request.auth.uid == uid || canEdit(listId));
        allow update: if canEdit(listId);
        allow delete: if signedIn() && (request.auth.uid == uid || canEdit(listId));
      }
    }

    // Invitations: the inviter creates one; the recipient (by matching email/phone) or the inviter
    // may read/update it (accepting flips status). Signed-in gate keeps it off the open internet;
    // the recipient contact is the addressing key.
    match /invitations/{inviteId} {
      allow create: if signedIn() && request.resource.data.inviterUserId == request.auth.uid;
      allow read, update: if signedIn();
    }
  }
}
